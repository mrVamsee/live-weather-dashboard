# Dependencies
# Never upload these; they are installed via 'npm install'
node_modules/
.pnpm-store/

# Production Build
# These folders are generated during 'npm run build'
build/
dist/
dist-ssr/
out/

# Environment Variables (CRITICAL SECURITY)
# Prevents your private API keys (like Visual Crossing) from being public
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
# Error files generated by npm or yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# Editor & System Files
# Files specific to your computer or VS Code
.vscode/
.idea/
.DS_Store
Thumbs.db
.history/

# Testing
coverage/